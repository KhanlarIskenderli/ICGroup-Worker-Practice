// Структура "Сотрудник"

Функция СоздатьРаботника(ФИО, Должность, Зарплата, ГодПриема) Экспорт

    Работник = Новый Структура;

    Работник.Вставить("ФИО", ФИО);
    Работник.Вставить("Должность", Должность);
    Работник.Вставить("Зарплата", Зарплата);
    Работник.Вставить("ГодПриема", ГодПриема);

    Возврат Работник;

КонецФункции
